{
    "gan_operators": [
        {
            "model_directory": "model_weights",
            "tokenizer_directory": "tokenizer",
            "tokenizer_type": "bert",
            "device": 0
        }
    ],
    "scoring_operator": {
        "scoring_names": [
            "synth",
            "drug",
            "logP",
            "number"
        ],
        "scoring_admet_names": [],

        "selection_names": [
            "synth",
            "drug",
            "logP"
        ],
        
        "property_config": {
            "synth": {"range": [0, 8], "higher_is_better": false},
            "drug": {"range": [0, 1], "higher_is_better": true},
            "logP": {"range": [-4, 7], "preferred_range": [2, 2.5]}
        },

        "scoring_parameters": {
            "sa_model": "./data/SA_score.pkl.gz"
        },
        "data_column_name": "smiles",
        "fitness_column_name": "fitness"
    },

    "scaffold_operator": {
        "fixed_substructure": "#C1=C(#)NC(#)=C(#)C1#",
        "min_mask_per_position": 1,
        "min_masks": 0,
        "max_masks": 12
    }
}